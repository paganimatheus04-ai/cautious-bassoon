
{
  "entities": {
    "QuoteRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuoteRequest",
      "type": "object",
      "description": "Represents a request for a packaging quote submitted by a user through the 'Solicitar Orçamento' functionality.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the QuoteRequest entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the person making the quote request."
        },
        "company": {
          "type": "string",
          "description": "The name of the company associated with the quote request."
        },
        "email": {
          "type": "string",
          "description": "The email address for contact regarding the quote request.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The telephone number for contact regarding the quote request."
        },
        "cidade": {
          "type": "string",
          "description": "The city of the requester."
        },
        "tipoEmbalagem": {
          "type": "string",
          "description": "The type of packaging requested."
        },
        "quantidade": {
          "type": "string",
          "description": "The estimated quantity requested."
        },
        "message": {
          "type": "string",
          "description": "Detailed message describing the user's packaging needs."
        },
        "requestDate": {
          "type": "string",
          "description": "The date and time when the quote request was submitted.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current processing status (e.g., 'New', 'Pending', 'Processed')."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "message",
        "requestDate",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/quoteRequests/{quoteRequestId}",
        "definition": {
          "entityName": "QuoteRequest",
          "schema": {
            "$ref": "#/backend/entities/QuoteRequest"
          },
          "description": "Stores individual packaging quote requests. Public write, admin read."
        }
      },
      {
        "path": "/roles_admin/{adminUid}",
        "definition": {
          "entityName": "admin",
          "schema": {
            "type": "object",
            "properties": {
              "isAdmin": { "type": "boolean" }
            }
          },
          "description": "Admin privileges registry."
        }
      }
    ]
  }
}
